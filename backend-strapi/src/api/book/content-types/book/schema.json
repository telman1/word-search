{
  "kind": "collectionType",
  "collectionName": "books",
  "info": {
    "singularName": "book",
    "pluralName": "books",
    "displayName": "Book",
    "description": "Books - name in Armenian and original language"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author"
    },
    "nameArmenian": {
      "type": "string",
      "required": true
    },
    "nameOriginalLanguage": {
      "type": "string",
      "required": true
    },
    "originalLanguageType": {
      "type": "enumeration",
      "enum": ["english", "french", "german", "italian", "other"],
      "required": true
    }
  }
}


{
  "kind": "collectionType",
  "collectionName": "authors",
  "info": {
    "singularName": "author",
    "pluralName": "authors",
    "displayName": "Author",
    "description": "Authors — names in Armenian and original language"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "listView": {
        "defaultSort": {
          "field": "id",
          "order": "ASC"
        }
      }
    }
  },
  "attributes": {
    "nameArmenian": {
      "type": "string",
      "required": true
    },
    "nameOriginalLanguage": {
      "type": "string",
      "required": true
    },
    "originalLanguageType": {
      "type": "enumeration",
      "enum": ["english", "french", "german", "italian", "other"],
      "required": true
    },
    "wordEntries": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::word-entry.word-entry",
      "mappedBy": "authors"
    }
  }
}

# Copy to .env for local development. Never commit .env.

HOST=0.0.0.0
PORT=1337

# Strapi secrets — generate unique values for production (e.g. openssl rand -base64 32)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
JWT_SECRET=
TRANSFER_TOKEN_SALT=

# Database: use SQLite (default) or PostgreSQL
DATABASE_CLIENT=sqlite

# PostgreSQL (e.g. Docker or Neon) — use connection string OR discrete vars
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# CORS: comma-separated origins; optional Vercel support for *.vercel.app
# CORS_ORIGIN=http://localhost:3000
# CORS_ALLOW_VERCEL=false
